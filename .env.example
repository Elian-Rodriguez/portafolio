# Puedes usar las variables VITE_* (recomendado) o las antiguas REACT_APP_*.
# Si defines ambas, tienen prioridad las VITE_*.

# ─── Contentful (CMS) ───────────────────────────────────────────────
# Panel: https://app.contentful.com  →  Settings → API keys
VITE_CONTENTFUL_SPACE=
VITE_CONTENTFUL_ENVIRONMENT=master
VITE_CONTENTFUL_ACCESS_TOKEN=

# Alternativa heredada (CRA):
# REACT_APP_SPACE=
# REACT_APP_ENVIRONMENT=master
# REACT_APP_ACCESS_TOKEN=

# ─── Telegram (formulario de contacto) ──────────────────────────────
# Crea un bot con @BotFather y obtén el chat_id con @userinfobot
VITE_TELEGRAM_BOT_TOKEN=
VITE_TELEGRAM_CHAT_ID=

# Alternativa heredada (CRA):
# REACT_APP_TELEGRAM_BOT_TOKEN=
# REACT_APP_CHAT_TELEGRAM=
